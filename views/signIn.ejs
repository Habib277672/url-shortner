<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In</title>
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family: "Syne", sans-serif;
        background: #f5f4f0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: 2rem;
      }
      .container {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 440px;
      }
      .hero {
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .hero h1 {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a18;
        letter-spacing: -0.5px;
        margin-bottom: 6px;
      }
      .hero p {
        font-size: 14px;
        color: #888780;
      }
      .card {
        background: #fff;
        border: 0.5px solid #d3d1c7;
        border-radius: 12px;
        padding: 1.5rem;
        width: 100%;
      }
      label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: #888780;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 14px;
      }
      label:first-of-type { margin-top: 0; }
      input {
        width: 100%;
        font-family: "DM Mono", monospace;
        font-size: 13px;
        padding: 0 14px;
        height: 42px;
        border: 0.5px solid #b4b2a9;
        border-radius: 8px;
        background: #f5f4f0;
        color: #1a1a18;
        outline: none;
        margin-top: 6px;
      }
      input:focus {
        border-color: #888780;
        background: #fff;
      }
      button[type="submit"] {
        width: 100%;
        height: 42px;
        font-family: "Syne", sans-serif;
        font-size: 13px;
        font-weight: 500;
        background: #1a1a18;
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 16px;
      }
      .error {
        background: #fde8e8;
        color: #b91c1c;
        font-size: 13px;
        padding: 10px 14px;
        border-radius: 8px;
        margin-bottom: 12px;
        text-align: center;
      }
      @media (max-width: 600px) {
        body { padding: 1rem; }
        .container { max-width: 100%; }
        .hero h1 { font-size: 22px; }
        input { font-size: 16px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="hero">
        <h1>Sign In</h1>
        <p>Welcome back to URL Shortener</p>
      </div>
      <div class="card">
        <% if (locals.error) { %>
          <div class="error"><%= error %></div>
        <% } %>
        <form action="/user/signin" method="post">
          <label>Email</label>
          <input type="email" placeholder="Enter Your Email" required name="email" />
          <label>Password</label>
          <input type="password" placeholder="Enter Your Password" required name="password" />
          <button type="submit">Sign In</button>
        </form>
        <p style="margin-top: 16px; font-size: 13px; color: #888780; text-align: center;">
          Don't have an account?
          <a href="/signup" style="color: #185fa5; text-decoration: none; font-weight: 500;">Sign Up</a>
        </p>
      </div>
    </div>
  </body>
</html>
